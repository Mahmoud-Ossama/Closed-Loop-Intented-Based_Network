{
  "environment": {
    "name": "RL-SDN Controller",
    "description": "Reinforcement Learning driven Software-Defined Network optimization",
    "mode": "production",
    "ryu_controller": {
      "base_url": "http://localhost:8080",
      "timeout_seconds": 5,
      "retry_attempts": 3,
      "retry_delay_seconds": 1
    },
    "network": {
      "switch_dpid": "0000000000000030",
      "link_capacity_mbps": 100.0,
      "stabilization_delay_seconds": 2.0,
      "num_ports": 3,
      "topology": {
        "main_path": ["core", "sp1", "lf1"],
        "backup_path": ["core", "sp2", "lf1"]
      }
    },
    "monitoring": {
      "active_service": "URLLC",
      "latency_cap_ms": 200.0,
      "main_pair": {
        "src": "G6_D1",
        "dst": "URLLC"
      },
      "backup_pair": {
        "src": "MNR_D",
        "dst": "MNR_SVR"
      }
    },
    "service_mapping": {
      "G6_D1": "URLLC",
      "G6_D2": "eMBB",
      "G6_IOT_D": "mMTC",
      "MNR_D": "URLLC"
    },
    "state_space": {
      "dimension": 12,
      "features": [
        "util_ran_agg",
        "util_agg_core",
        "util_core_sp1",
        "util_core_sp2",
        "util_sp1_lf1",
        "util_sp2_lf1",
        "latency",
        "packet_loss_rate",
        "total_traffic_load",
        "service_urllc",
        "service_embb",
        "service_mmtc"
      ],
      "normalization": {
        "method": "min-max",
        "range": [0.0, 1.0]
      }
    },
    "action_space": {
      "type": "discrete",
      "dimension": 5,
      "actions": {
        "0": {
          "name": "do_nothing",
          "description": "Maintain current network state"
        },
        "1": {
          "name": "route_to_queue_0",
          "description": "Send UDP traffic to high-priority queue",
          "target": {
            "queue_id": 0,
            "protocol": "UDP",
            "port": 5002,
            "destination_ip": "20.0.0.2"
          }
        },
        "2": {
          "name": "route_to_queue_1",
          "description": "Send UDP traffic to low-priority queue",
          "target": {
            "queue_id": 1,
            "protocol": "UDP",
            "port": 5002,
            "destination_ip": "20.0.0.1"
          }
        },
        "3": {
          "name": "apply_rate_limit",
          "description": "Apply 500 kbps rate limit to port s1-eth1",
          "target": {
            "port_name": "core-eth-uplink",
            "max_rate_bps": 500000
          }
        },
        "4": {
          "name": "remove_rate_limit",
          "description": "Remove rate limit, restore to 1 Mbps",
          "target": {
            "port_name": "core-eth-uplink",
            "max_rate_bps": 1000000
          }
        }
      }
    },
    "episode": {
      "max_steps": 50,
      "timeout_seconds": 300
    }
  },
  "agent": {
    "algorithm": "DQN",
    "neural_network": {
      "architecture": "MLP",
      "input_dim": 12,
      "output_dim": 5,
      "hidden_layers": [64, 64],
      "activation": "ReLU"
    },
    "hyperparameters": {
      "learning_rate": 0.001,
      "gamma": 0.99,
      "epsilon_start": 1.0,
      "epsilon_end": 0.01,
      "epsilon_decay": 0.995,
      "batch_size": 64,
      "target_update_frequency": 100
    },
    "replay_buffer": {
      "capacity": 10000,
      "min_size_for_training": 1000
    },
    "optimizer": {
      "type": "Adam",
      "weight_decay": 0.0
    },
    "loss_function": "MSE"
  },
  "training": {
    "num_episodes": 1000,
    "warmup_steps": 1000,
    "evaluation_frequency": 50,
    "save_frequency": 100,
    "early_stopping": {
      "enabled": true,
      "patience": 100,
      "min_improvement": 0.01
    },
    "checkpoints": {
      "directory": "./checkpoints",
      "save_best_only": false,
      "max_checkpoints_to_keep": 5
    }
  },
  "reward_function": {
    "type": "multi_objective",
    "components": {
      "utilization_penalty": {
        "enabled": true,
        "weight": 1.0,
        "formula": "mean(link_utilization)^2",
        "description": "Quadratic penalty for high link utilization"
      },
      "packet_loss_penalty": {
        "enabled": true,
        "weight": 100.0,
        "formula": "packet_loss_rate * weight",
        "description": "Heavy penalty for packet drops"
      },
      "balance_bonus": {
        "enabled": true,
        "weight": 1.0,
        "formula": "1 / (1 + std(link_utilization))",
        "description": "Reward for balanced link utilization"
      },
      "congestion_threshold": {
        "enabled": true,
        "threshold": 0.8,
        "penalty": 5.0,
        "description": "Extra penalty if any link exceeds 80% utilization"
      }
    },
    "normalization": {
      "clip_range": [-10.0, 10.0]
    }
  },
  "logging": {
    "enabled": true,
    "level": "INFO",
    "console_output": true,
    "file_output": {
      "enabled": true,
      "directory": "./logs",
      "filename_pattern": "rl_sdn_{timestamp}.log",
      "rotation": {
        "max_bytes": 10485760,
        "backup_count": 5
      }
    },
    "tensorboard": {
      "enabled": true,
      "log_dir": "./runs",
      "flush_interval_seconds": 30,
      "metrics": [
        "episode_reward",
        "episode_length",
        "average_q_value",
        "loss",
        "epsilon",
        "learning_rate"
      ]
    },
    "metrics": {
      "track_state_statistics": true,
      "track_action_distribution": true,
      "track_reward_components": true
    }
  },
  "evaluation": {
    "enabled": true,
    "num_episodes": 10,
    "epsilon": 0.0,
    "render": false,
    "save_trajectories": true,
    "baseline_policies": [
      {
        "name": "random",
        "description": "Random action selection"
      },
      {
        "name": "do_nothing",
        "description": "Always select action 0"
      }
    ]
  },
  "traffic_generation": {
    "description": "Traffic patterns for Mininet environment",
    "patterns": [
      {
        "name": "constant_load",
        "type": "UDP",
        "source": "h2",
        "destination": "10.0.0.1",
        "port": 5002,
        "bandwidth": "800k",
        "duration": 3600
      },
      {
        "name": "bursty_load",
        "type": "UDP",
        "source": "h3",
        "destination": "10.0.0.1",
        "port": 5003,
        "bandwidth": "1200k",
        "burst_interval": 10,
        "burst_duration": 5
      }
    ],
    "background_traffic": {
      "enabled": true,
      "type": "ping",
      "interval_seconds": 1
    }
  },
  "api_endpoints": {
    "ryu": {
      "port_stats": "/stats/port/{dpid}",
      "flow_stats": "/stats/flow/{dpid}",
      "qos_queue": "/qos/queue/{switch_id}",
      "qos_rules": "/qos/rules/{switch_id}",
      "network_reset": "/network/reset",
      "latency": "/latency/{src}/{dst}",
      "links_utilization": "/links/utilization"
    }
  },
  "debugging": {
    "mock_mode": {
      "enabled": false,
      "description": "Use mock environment for offline training"
    },
    "verbose_actions": true,
    "log_state_transitions": true,
    "save_failed_requests": true
  },
  "system": {
    "random_seed": 42,
    "device": "cpu",
    "num_workers": 1,
    "deterministic": true
  },
  "metadata": {
    "version": "1.0.0",
    "created_date": "2026-03-09",
    "author": "Ali",
    "description": "Production configuration for RL-based SDN traffic optimization prototype",
    "notes": [
      "State space expanded to 12 features with service intent encoding",
      "Single DQN agent for simplicity",
      "QoS actions are enforced at Core switch",
      "2-second stabilization delay after each action",
      "Traffic generation required in Mininet for meaningful learning"
    ]
  }
}