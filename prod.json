    "episode": {
      "max_steps": 15,
      "timeout_seconds": 300,
      "call_network_reset_on_reset": false
    }
  },
  "agent": {
    "algorithm": "DQN",
    "neural_network": {
      "architecture": "MLP",
      "input_dim": 6,
      "output_dim": 4,
      "hidden_layers": [64, 64],
      "activation": "ReLU"
    },
    "hyperparameters": {
      "learning_rate": 0.001,
      "gamma": 0.99,
      "epsilon_start": 1.0,
      "epsilon_end": 0.01,
      "epsilon_decay": 0.999,
      "batch_size": 64,
      "target_update_frequency": 100
    },
    "replay_buffer": {
      "capacity": 10000,
      "min_size_for_training": 1000
    },
    "optimizer": {
      "type": "Adam",
      "weight_decay": 0.0
    },
    "loss_function": "MSE"
  },
  "training": {
    "num_episodes": 100,
    "warmup_steps": 200,
    "evaluation_frequency": 10,
    "save_frequency": 25,
    "run_startup_setup": true,
    "early_stopping": {
      "enabled": true,
      "patience": 100,
      "min_improvement": 0.01
    },
    "checkpoints": {
      "directory": "./checkpoints",
      "save_best_only": false,
      "max_checkpoints_to_keep": 5
    }
  },
  "reward_function": {
    "type": "operational_qos",
    "components": {
      "latency_penalty": {
        "enabled": true,
        "weight": 2.5,
        "description": "Penalty for high latency in realistic 10-80 ms band"
      },
      "packet_loss_penalty": {
        "enabled": true,
        "weight": 3.0,
        "description": "Penalty for packet loss in 0-5 percent operating range"
      },
      "utilization_penalty": {
        "enabled": true,
        "weight": 1.2,
        "description": "Penalty for sustained high average path utilization"
      },
      "throughput_bonus": {
        "enabled": true,
        "weight": 1.5,
        "description": "Reward for maintaining higher normalized throughput"
      },
      "congestion_threshold": {
        "enabled": true,
        "threshold": 0.9,
        "penalty": 2.0,
        "description": "Penalty when any path utilization crosses threshold"
      },
      "failover_penalty": {
        "enabled": true,
        "weight": 0.2,
        "description": "Small cost to avoid unnecessary backup-path residency"
      },
      "action_repeat_penalty": {
        "enabled": true,
        "weight": 0.1,
        "description": "Small penalty to discourage repeated identical actions"
      },
      "outcome_improvement_bonus": {
        "enabled": true,
        "weight": 1.0,
        "max_bonus": 0.2,
        "description": "Bonus for actions that reduce max path congestion"
      }
    },
    "normalization": {
      "clip_range": [-10.0, 10.0]
    }
  },
  "logging": {
    "enabled": true,
    "level": "INFO",
    "console_output": true,
    "file_output": {
      "enabled": true,
      "directory": "./logs",
      "filename_pattern": "rl_sdn_{timestamp}.log",
      "rotation": {
        "max_bytes": 10485760,
        "backup_count": 5
      }
    },
    "tensorboard": {
      "enabled": true,
      "log_dir": "./runs",
      "flush_interval_seconds": 30,
      "metrics": [
        "episode_reward",
        "episode_length",
        "average_q_value",
        "loss",
        "epsilon",
        "learning_rate"
      ]
    },
    "metrics": {
      "track_state_statistics": true,
      "track_action_distribution": true,
      "track_reward_components": true
    }
  },
  "evaluation": {
    "enabled": true,
    "num_episodes": 10,
    "epsilon": 0.0,
    "render": false,
    "save_trajectories": true,
    "run_startup_setup": false,
    "baseline_policies": [
      {
        "name": "random",
        "description": "Random action selection"
      },
      {
        "name": "do_nothing",
        "description": "Always select action 0"
      }
    ]
  },
  "traffic_generation": {
    "description": "Traffic patterns for Mininet environment",
    "patterns": [
      {
        "name": "urllc_flow",
        "type": "UDP",
        "source": "G6_D1",
        "destination": "20.0.0.1",
        "port": 5001,
        "bandwidth": "6m",
        "duration": 3600
      },
      {
        "name": "embb_flow",
        "type": "UDP",
        "source": "G6_D2",
        "destination": "20.0.0.2",
        "port": 5002,
        "bandwidth": "8m",
        "duration": 3600
      },
      {
        "name": "mmtc_flow",
        "type": "UDP",
        "source": "G6_IOT_D",
        "destination": "20.0.0.3",
        "port": 5003,
        "bandwidth": "3m",
        "duration": 3600
      }
    ],
    "background_traffic": {
      "enabled": true,
      "type": "ping",
      "interval_seconds": 1
    }
  },
  "api_endpoints": {
    "ryu": {
      "router_ovsdb": "/v1.0/conf/switches/{switch_id}/ovsdb_addr",
      "router_node": "/router/{switch_id}",
      "qos_queue": "/qos/queue/{switch_id}",
      "qos_rules": "/qos/rules/{switch_id}",
      "network_reset": "/network/reset",
      "latency": "/latency/{src}/{dst}",
      "links_utilization": "/links/utilization"
    }
  },
  "debugging": {
    "verbose_actions": true,
    "log_state_transitions": true,
    "save_failed_requests": true,
    "dry_run_setup": false
  },
  "system": {
    "random_seed": 42,
    "device": "cpu",
    "num_workers": 1,
    "deterministic": true
  },
  "metadata": {
    "version": "2.0.0",
    "created_date": "2026-03-09",
    "author": "Ali",
    "description": "Routing-first production configuration for RL-based SDN optimization",
    "notes": [
      "Routing and baseline QoS are initialized once at startup",
      "Runtime actions are optimization-only: update_queue, failover, reroute",
      "State vector moved to 6 operational features with failover awareness",
      "Main and backup path capacities are 20 Mbps and 10 Mbps",
      "Latency normalization is tuned for 10-80 ms operating range"
    ]
  }
}
