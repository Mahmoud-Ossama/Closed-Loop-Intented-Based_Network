{
  "environment": {
    "name": "RL-SDN Controller",
    "description": "Reinforcement Learning driven Software-Defined Network optimization",
    "mode": "production",
    "ryu_controller": {
      "base_url": "http://172.17.0.2:8080",
      "timeout_seconds": 15,
      "retry_attempts": 5,
      "retry_delay_seconds": 1
    },
    "network": {
      "switch_dpid": "0000000000000030",
      "main_link_capacity_mbps": 20.0,
      "backup_link_capacity_mbps": 10.0,
      "stabilization_delay_seconds": 1.0,
      "num_ports": 3,
      "topology": {
        "main_path": ["core", "sp1", "lf1"],
        "backup_path": ["core", "sp2", "lf1"]
      },
      "switch_dpids": {
        "RAN": "0000000000000010",
        "agg": "0000000000000020",
        "core": "0000000000000030",
        "sp1": "0000000000000040",
        "sp2": "0000000000000041",
        "lf1": "0000000000000050"
      }
    },
    "monitoring": {
      "latency_min_ms": 10.0,
      "latency_max_ms": 80.0,
      "packet_loss_max_percent": 5.0,
      "main_pair": {
        "src": "G6_D1",
        "dst": "URLLC"
      },
      "backup_pair": {
        "src": "MNR_D",
        "dst": "MNR_SVR"
      }
    },
    "state_space": {
      "dimension": 6,
      "features": [
        "latency",
        "packet_loss",
        "throughput",
        "main_link_util",
        "backup_link_util",
        "failover_active"
      ],
      "normalization": {
        "method": "min-max",
        "range": [0.0, 1.0]
      }
    },
    "action_space": {
      "type": "discrete",
      "dimension": 4,
      "actions": {
        "0": {
          "name": "do_nothing",
          "description": "Keep current routing and queue settings"
        },
        "1": {
          "name": "update_queue",
          "description": "Adjust queue allocation on main core uplink",
          "target": {
            "switch_dpid": "0000000000000030",
            "qos_config": {
              "port_name": "core-eth2",
              "type": "linux-htb",
              "max_rate": "20000000",
              "queues": [
                {
                  "max_rate": "20000000"
                },
                {
                  "min_rate": "10000000"
                },
                {
                  "min_rate": "6000000"
                },
                {
                  "max_rate": "4000000"
                }
              ]
            }
          }
        },
        "2": {
          "name": "failover",
          "description": "Switch service route to backup path via spine2",
          "target": {
            "switch_dpid": "0000000000000030",
            "route": {
              "destination": "20.0.0.0/24",
              "gateway": "14.0.0.2"
            },
            "set_failover_active": true
          }
        },
        "3": {
          "name": "reroute",
          "description": "Restore service route to main path via spine1",
          "target": {
            "switch_dpid": "0000000000000030",
            "route": {
              "destination": "20.0.0.0/24",
              "gateway": "13.0.0.2"
            },
            "set_failover_active": false
          }
        }
      }
    },
    "startup_setup": {
      "enabled": true,
      "continue_on_error": false,
      "ovsdb_addr": "tcp:127.0.0.1:6632",
      "routing": {
        "node_order": [
          "0000000000000010",
          "0000000000000020",
